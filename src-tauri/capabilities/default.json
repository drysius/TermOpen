{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "deep-link:default",
    "dialog:default",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://raw.githubusercontent.com/*" },
        { "url": "https://*.workers.dev/*" },
        { "url": "http://localhost/*" },
        { "url": "https://localhost/*" }
      ]
    }
  ]
}
