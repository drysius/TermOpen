{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "termopen",
  "version": "0.1.0",
  "identifier": "com.urubucode.termopen",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TermOpen",
        "center": true,
        "width": 380,
        "height": 600,
        "minWidth": 350,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["termopen", "openterm", "ssh", "sftp"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
